rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================
    // 🛡️ Helper Functions
    // =========================================================
    
    // Check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is accessing their own document
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Get user role from 'userRoles' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role;
    }

    // Check if user is Admin or SuperAdmin
    function isAdmin() {
      return isAuthenticated() && (getUserRole() in ['ADMIN', 'SUPER_ADMIN', 'admin', 'superadmin', 'super_admin']);
    }

    // Check if user is SuperAdmin
    function isSuperAdmin() {
      return isAuthenticated() && (getUserRole() in ['SUPER_ADMIN', 'superadmin', 'super_admin']);
    }

    // =========================================================
    // 📂 Collection Rules
    // =========================================================

    // 1. Users Collection
    // - Read: User themselves or Admins
    // - Write: User themselves (update profile) or Admins
    match /users/{userId} {
      allow read: if isUser(userId) || isAdmin();
      allow create: if isAuthenticated() && isUser(userId); // Initial profile creation
      allow update: if isUser(userId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // 2. User Roles (Security Critical)
    // - Read: Authenticated users need to read their own role (mapped in AuthContext)
    //         However, stricter rule: only read own role? 
    //         AuthContext loads `userRoles/{uid}`.
    match /userRoles/{userId} {
      // 自己的角色可以讀，或者是管理員 (Admin/SuperAdmin) 可以讀取所有人的角色
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isSuperAdmin(); // Only SuperAdmin can assign roles
    }

    // 3. Stores (Public Read, Admin Write)
    // - Read: Public
    // - Write: Admin only
    match /stores/{type}/list/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Support Collection Group queries for stores if needed
    match /{path=**}/list/{storeId} {
      allow read: if true;
    }

    // 4. Orders
    // - Read: User (own orders) or Admin (all orders)
    // - Create: Authenticated users (must act as themselves)
    // - Update: Admin (status update) or User (cancel only)
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid; // prevent spoofing

      allow update: if isAdmin() // Admins can update status anywhere
                    || (
                       // Users can only update their own orders
                       isUser(resource.data.userId) 
                       // AND only if updating status to 'cancelled'
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                       && request.resource.data.status == 'cancelled'
                       // AND only if current status is 'pending' or 'confirmed' (policy?)
                       // simplifying for now: allow cancel
                    );
    }
    
    // 5. Statistics (Admin Only)
    // Usually aggregated on client or via Functions, but if stored:
    match /statistics/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 6. Counters (For Order Numbering)
    // - Read/Write: Authenticated users need to increment counters during order creation
    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // 7. System (For initialization flags)
    // - Read: Authenticated users (to check if stores are initialized)
    // - Write: Admin only (to prevent users from modifying system state)
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}